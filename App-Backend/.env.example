# VRoom Backend API Configuration
# Copy this file to .env and fill in your values.
# Do NOT commit your actual .env file to version control.

# ── Authentication ─────────────────────────────────────────────────────
# Replace with a strong secret key for API authentication
VROOM_API_KEY="your-secret-api-key"

# ── S3 Configuration (Optional) ────────────────────────────────────────
# If left blank, the backend will automatically fall back to saving
# outputs to your local disk in the `jobs_data/` directory.
AWS_S3_BUCKET="vroom-pipeline-outputs"
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="..."

# ── Conda Environments (Local only) ────────────────────────────────────
# These tell the subprocess runner which conda environments to use 
# when running locally (not used in Modal).
PIPELINE_CONDA_ENV="pipeline"
MASKS_CONDA_ENV="masks"
